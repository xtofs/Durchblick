{
	"version": "2.0.0",
	"tasks": [
		{
			"label": "build Durchblick.Tool",
			"type": "process",
			"command": "dotnet",
			"args": [
				"build",
				"${workspaceFolder}/src/Durchblick.Tool/Durchblick.Tool.csproj",
				"--configuration",
				"Debug"
			],
			"options": {
				"cwd": "${workspaceFolder}"
			},
			"group": "build",
			"problemMatcher": "$msCompile"
		}
	]
}